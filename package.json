{
  "name": "balkon-dergisi",
  "version": "1.0.0",
  "description": "Digital magazine platform for Sezai Karakoç Anadolu Lisesi",
  "private": true,
  "keywords": [
    "digital-magazine",
    "nextjs",
    "education",
    "student-publication",
    "sezai-karakoc-anadolu-lisesi"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next",
    "configure:r2-cors": "tsx configure-r2-cors.ts",
    "postinstall": "node scripts/copy-pdf-worker.mjs",
    "analyze": "cross-env ANALYZE=true pnpm build",
    "analyze:server": "cross-env ANALYZE=server pnpm build",
    "analyze:client": "cross-env ANALYZE=client pnpm build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@sentry/nextjs": "^10.27.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/storage-js": "^2.105.4",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-query": "^5.90.16",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.542.0",
    "motion": "^12.23.12",
    "next": "15.5.18",
    "pdfjs-dist": "^5.4.394",
    "react": "19.1.2",
    "react-dom": "19.1.2",
    "react-hook-form": "^7.62.0",
    "react-pageflip": "^2.0.3",
    "recharts": "^3.6.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "16.3.0-preview.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "import-in-the-middle": "3.0.1",
    "require-in-the-middle": "8.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "import-in-the-middle": "3.0.1"
    }
  }
}
