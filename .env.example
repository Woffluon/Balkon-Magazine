# Supabase Configuration
# Get these values from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Example:
# NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Storage Provider Configuration
# Decide which storage backend to use: 'supabase' (default) or 'r2'
NEXT_PUBLIC_STORAGE_PROVIDER=supabase

# Cloudflare R2 Configuration (Required if NEXT_PUBLIC_STORAGE_PROVIDER=r2)
# Get these values from your Cloudflare Dashboard -> R2 -> Manage R2 API Tokens
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_BUCKET_NAME=your_r2_bucket_name
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxxxx.r2.dev

# Site Configuration
# Base URL for the site (used for canonical URLs and OG images)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PDF.js Worker Configuration
# Path to the PDF.js worker file (defaults to /pdf.worker.min.mjs)
NEXT_PUBLIC_PDFJS_WORKER_URL=/pdf.worker.min.mjs

# Sentry Configuration (Optional - for production error tracking)
# Get your DSN from https://sentry.io/
# Server-side DSN (used in server.config.ts and edge.config.ts)
# SENTRY_DSN=your_sentry_dsn
# Client-side DSN (used in client.config.ts)
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
# 
# Example:
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
#
# Note: Both DSNs are typically the same value. The NEXT_PUBLIC_ prefix
# makes it available to client-side code.